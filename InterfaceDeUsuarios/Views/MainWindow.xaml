<Window x:Class="InterfaceDeUsuarios.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:InterfaceDeUsuarios.ViewModel"
        mc:Ignorable="d"
        Height="700" 
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Estilos necessários para os controles -->

        <!-- Estilo para TextBox do formulário -->
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="5,2,5,5"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Estilo para PasswordBox do formulário -->
        <Style TargetType="PasswordBox" x:Key="FormPasswordBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="5,2,5,5"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Estilo para ComboBox do formulário -->
        <Style TargetType="ComboBox" x:Key="FormComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="5,2,5,5"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Estilo para DatePicker do formulário -->
        <Style TargetType="DatePicker" x:Key="FormDatePicker">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="5,2,5,5"/>
            <Setter Property="Height" Value="35"/>
        </Style>

        <!-- Estilo padrão para botões -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para Labels -->
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5,5,5,0"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <!-- Estilo para TabItems -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl Margin="10">
            <!-- Aba 1: Consulta de Usuários -->
            <TabItem Header="🔍 CONSULTAR USUÁRIOS">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Título -->
                    <Border Grid.Row="0" Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                        <TextBlock Text="📋 CONSULTA DE USUÁRIOS" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Painel de Busca -->
                    <Border Grid.Row="1" Background="#ECF0F1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Label Content="Buscar por:" Grid.Column="0" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" 
                                      ItemsSource="{Binding TiposBusca}"
                                      SelectedIndex="{Binding TipoBusca}"
                                      Style="{StaticResource FormComboBox}"
                                      Margin="5,0"/>

                            <Label Content="Termo:" Grid.Column="2" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3" 
                                     Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}"
                                     Margin="5,0"/>

                            <Button Grid.Column="4" 
                                    Content="🔍 BUSCAR" 
                                    Command="{Binding BuscarCommand}"
                                    Background="#3498DB" 
                                    Foreground="White"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid com Lista de Usuários -->
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding Usuarios}"
                              SelectedItem="{Binding UsuarioSelecionado, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#F2F2F2"
                              FontSize="12"
                              SelectionMode="Single"
                              BorderBrush="#BDC3C7"
                              BorderThickness="1" HorizontalAlignment="Left" Margin="0,84,0,0" Grid.RowSpan="2" Width="1054">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Nome Completo" Binding="{Binding NomeCompleto}" Width="200"/>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                            <DataGridTextColumn Header="Gênero" Binding="{Binding Genero}" Width="100"/>
                            <DataGridTextColumn Header="País" Binding="{Binding Pais}" Width="120"/>
                            <DataGridTextColumn Header="Cadastro" Binding="{Binding DataCadastro, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Último Login" Binding="{Binding UltimoLogin, StringFormat=dd/MM/yyyy HH:mm}" Width="130"/>
                            <DataGridCheckBoxColumn Header="Email Verif." Binding="{Binding EmailVerificado}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Aba 2: Editar Usuários -->
            <TabItem Header="✏️ EDITAR USUÁRIO">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Título -->
                    <Border Grid.Row="0" Background="#2C3E50" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                        <TextBlock Text="✏️ EDIÇÃO DE USUÁRIOS" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Formulário de Edição -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Background="#ECF0F1" CornerRadius="5" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Coluna 1 -->
                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <TextBlock Text="📌 DADOS PESSOAIS" 
                                               FontSize="14" 
                                               FontWeight="Bold" 
                                               Foreground="#2C3E50"
                                               Margin="0,0,0,10"/>

                                    <!-- ID (somente leitura) -->
                                    <Label Content="ID:"/>
                                    <TextBox Text="{Binding UsuarioSelecionado.Id}" 
                                             IsEnabled="False"
                                             Style="{StaticResource FormTextBox}"
                                             Background="#D5D8DC"/>

                                    <!-- Username (somente leitura) -->
                                    <Label Content="Username:"/>
                                    <TextBox Text="{Binding UsuarioSelecionado.Username}" 
                                             IsEnabled="False"
                                             Style="{StaticResource FormTextBox}"
                                             Background="#D5D8DC"/>

                                    <!-- Nome Completo (editável) -->
                                    <Label Content="Nome Completo:*"/>
                                    <TextBox Text="{Binding UsuarioSelecionado.NomeCompleto, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBox}"/>

                                    <!-- Email (editável) -->
                                    <Label Content="Email:*"/>
                                    <TextBox Text="{Binding UsuarioSelecionado.Email, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBox}"/>

                                    <!-- Telefone (editável) -->
                                    <Label Content="Telefone:"/>
                                    <TextBox Text="{Binding UsuarioSelecionado.Telefone}"
                                             Style="{StaticResource FormTextBox}"/>

                                    <!-- Gênero (editável) -->
                                    <Label Content="Gênero:"/>
                                    <ComboBox ItemsSource="{Binding ListaGeneros}"
                                              SelectedItem="{Binding UsuarioSelecionado.Genero}"
                                              Style="{StaticResource FormComboBox}"/>
                                </StackPanel>

                                <!-- Coluna 2 -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="🔐 INFORMAÇÕES ADICIONAIS" 
                                               FontSize="14" 
                                               FontWeight="Bold" 
                                               Foreground="#2C3E50"
                                               Margin="0,0,0,10"/>

                                    <!-- País (editável) -->
                                    <Label Content="País:"/>
                                    <ComboBox ItemsSource="{Binding ListaPaises}"
                                              SelectedItem="{Binding UsuarioSelecionado.Pais}"
                                              Style="{StaticResource FormComboBox}"
                                              IsEditable="True"/>

                                    <!-- Data Nascimento (editável) -->
                                    <Label Content="Data Nascimento:"/>
                                    <DatePicker SelectedDate="{Binding UsuarioSelecionado.DataNascimento}"
                                                Style="{StaticResource FormDatePicker}"/>

                                    <!-- Email Verificado (editável) -->
                                    <CheckBox Content="Email Verificado"
                                              IsChecked="{Binding UsuarioSelecionado.EmailVerificado}"
                                              VerticalAlignment="Center"/>

                                    <!-- Data Cadastro (somente leitura) -->
                                    <Label Content="Data Cadastro:" Margin="5,15,5,0"/>
                                    <TextBox Text="{Binding UsuarioSelecionado.DataCadastro, StringFormat=dd/MM/yyyy HH:mm:ss}" 
                                             IsEnabled="False"
                                             Style="{StaticResource FormTextBox}"
                                             Background="#D5D8DC"/>

                                    <!-- Último Login (somente leitura) -->
                                    <Label Content="Último Login:"/>
                                    <TextBox Text="{Binding UsuarioSelecionado.UltimoLogin, StringFormat=dd/MM/yyyy HH:mm:ss}" 
                                             IsEnabled="False"
                                             Style="{StaticResource FormTextBox}"
                                             Background="#D5D8DC"/>

                                    <!-- Senha (editável) -->
                                    <Label Content="Nova Senha:"/>
                                    <PasswordBox x:Name="txtNovaSenha" 
                                                 Style="{StaticResource FormPasswordBox}"/>

                                    <Label Content="Confirmar Senha:"/>
                                    <PasswordBox x:Name="txtConfirmarSenha" 
                                                 Style="{StaticResource FormPasswordBox}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </ScrollViewer>

                    <!-- Botões de Ação -->
                    <Border Grid.Row="2" Background="#ECF0F1" CornerRadius="5" Padding="10" Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="💾 SALVAR ALTERAÇÕES" 
                                    Command="{Binding SalvarCommand}"
                                    Background="#27AE60" 
                                    Foreground="White"
                                    Width="150"/>

                            <Button Content="➕ NOVO USUÁRIO" 
                                    Command="{Binding NovoCommand}"
                                    Background="#3498DB" 
                                    Foreground="White"
                                    Width="150"/>

                            <Button Content="🗑️ LIMPAR" 
                                    Command="{Binding LimparCommand}"
                                    Background="#95A5A6" 
                                    Foreground="White"
                                    Width="120"/>

                            <Button Content="🔄 RECARREGAR" 
                                    Command="{Binding CarregarUsuariosCommand}"
                                    Background="#F39C12" 
                                    Foreground="White"
                                    Width="120"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>